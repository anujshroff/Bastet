@model SubnetDetailsViewModel

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Subnet Details</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Description</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Description) ? "N/A" : Model.Description)</dd>
            
            <dt class="col-sm-4">Tags</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Tags) ? "None" : Model.Tags)</dd>

            @if (!string.IsNullOrEmpty(Model.AzureResourceId))
            {
                // Per-subnet portal pages are nearly empty — for subnet resource IDs we link to the
                // parent VNet's /subnets list instead, which renders the useful subnet table.
                string portalPath = Model.AzureResourceId;
                int subnetSegment = portalPath.IndexOf("/subnets/", StringComparison.OrdinalIgnoreCase);
                if (subnetSegment >= 0)
                {
                    portalPath = portalPath.Substring(0, subnetSegment) + "/subnets";
                }
                string portalUrl = $"https://portal.azure.com/#@/resource{portalPath}";

                <dt class="col-sm-4">Azure Resource</dt>
                <dd class="col-sm-8">
                    <a href="@portalUrl" target="_blank" rel="noopener noreferrer">View in Azure Portal</a>
                </dd>
            }

            <dt class="col-sm-4">Created</dt>
            <dd class="col-sm-8">@Model.CreatedAt.ToString("g")</dd>
            
            <dt class="col-sm-4">Last Modified</dt>
            <dd class="col-sm-8">@(Model.LastModifiedAt.HasValue ? Model.LastModifiedAt.Value.ToString("g") : "Never")</dd>
            
            <dt class="col-sm-4">Created By</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.CreatedBy) ? "Unknown" : Model.CreatedBy)</dd>
            
            <dt class="col-sm-4">Modified By</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.ModifiedBy) ? "Never" : Model.ModifiedBy)</dd>
        </dl>
    </div>
</div>
